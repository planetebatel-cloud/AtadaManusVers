# ATADA Backend — Environment Variables
# Copy this file to .env and fill in real values.

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./atada.db

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# SMS OTP (mock in dev — prints to console)
# Twilio prod values:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Stripe (test mode by default — get real keys from dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER

# MiniMax LLM (empty → mock chat responses + parser disabled)
# Get from minimax.io. Required for AI chat and screenshot parser.
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_MODEL=MiniMax-Text-01

# Google Maps (empty → haversine fallback for commute, no external calls)
# Required for accurate drive/transit times and geocoding.
GOOGLE_MAPS_API_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
